{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "AUTH_MODE",
    "QUOTE_REPOSITORY_MODE",
    "AI_PROVIDER",
    "NEXT_PUBLIC_APP_NAME",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "OPENAI_API_KEY",
    "OPENAI_MODEL",
    "OPENAI_REASONING_INTAKE",
    "OPENAI_REASONING_ROUTING",
    "OPENAI_REASONING_PACKAGING",
    "HOTELBEDS_PROVIDER",
    "HOTELBEDS_BASE_URL",
    "HOTELBEDS_DEFAULT_LANGUAGE",
    "HOTELBEDS_TIMEOUT_MS",
    "HOTELBEDS_HOTELS_API_KEY",
    "HOTELBEDS_HOTELS_SECRET",
    "HOTELBEDS_ACTIVITIES_API_KEY",
    "HOTELBEDS_ACTIVITIES_SECRET",
    "HOTELBEDS_TRANSFERS_API_KEY",
    "HOTELBEDS_TRANSFERS_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "AUTH_MODE",
        "QUOTE_REPOSITORY_MODE",
        "AI_PROVIDER",
        "NEXT_PUBLIC_APP_NAME",
        "NEXT_PUBLIC_API_BASE_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_URL",
        "SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "OPENAI_API_KEY",
        "OPENAI_MODEL",
        "OPENAI_REASONING_INTAKE",
        "OPENAI_REASONING_ROUTING",
        "OPENAI_REASONING_PACKAGING",
        "HOTELBEDS_PROVIDER",
        "HOTELBEDS_BASE_URL",
        "HOTELBEDS_DEFAULT_LANGUAGE",
        "HOTELBEDS_TIMEOUT_MS",
        "HOTELBEDS_HOTELS_API_KEY",
        "HOTELBEDS_HOTELS_SECRET",
        "HOTELBEDS_ACTIVITIES_API_KEY",
        "HOTELBEDS_ACTIVITIES_SECRET",
        "HOTELBEDS_TRANSFERS_API_KEY",
        "HOTELBEDS_TRANSFERS_SECRET"
      ],
      "outputs": []
    },
    "@alana/web#build": {
      "outputs": [".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
